{
  "name": "prompt-dictionary",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first prompt management tool for software developers",
  "scripts": {
    "setup:local": "node scripts/setup-local.mjs",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @prompt-dictionary/database db:generate",
    "db:migrate": "pnpm --filter @prompt-dictionary/database db:migrate",
    "db:deploy": "pnpm --filter @prompt-dictionary/database db:migrate:prod",
    "db:seed": "pnpm --filter @prompt-dictionary/database db:seed",
    "db:studio": "pnpm --filter @prompt-dictionary/database db:studio",
    "sync:default-prompts": "pnpm --filter @prompt-dictionary/server sync:default-prompts",
    "import:local-prompts": "pnpm --filter @prompt-dictionary/server import:local-prompts"
  },
  "devDependencies": {
    "sql.js": "^1.14.1",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0"
  }
}
