# Server
PORT=3001
NODE_ENV=development

# Database - SQLite file path relative to packages/database/prisma/
DATABASE_URL=file:./dev.db

# AI (optional - leave empty to skip AI features)
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=

# Optional local prompt import directory.
# Leave empty in shared repos. Set this only on your own machine.
LOCAL_PROMPT_DIR=
